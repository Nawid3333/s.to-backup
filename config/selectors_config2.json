{
  "site_url": "https://s.to",
  "login_page": "https://s.to/login",
  "account_page": "https://s.to/account",
  "selectors": {
    "login": {
      "username_field": [
        { "type": "css", "value": "input#email" },
        { "type": "css", "value": "input[type='email']" },
        { "type": "css", "value": "input[name='email']" },
        { "type": "css", "value": "input.form-control[type='email']" }
      ],
      "password_field": [
        { "type": "css", "value": "input#password" },
        { "type": "css", "value": "input[type='password']" },
        { "type": "css", "value": "input[name='password']" },
        { "type": "css", "value": "input.form-control[type='password']" }
      ],
      "submit_button": [
        { "type": "css", "value": "button[type='submit']" },
        { "type": "css", "value": "input[type='submit']" },
        { "type": "css", "value": "button.btn-primary" },
        { "type": "css", "value": "button.btn" }
      ]
    },
    "series_detail": {
      "episode_rows": ".episode-table tbody tr.episode-row",
      "episode_number": "th.episode-number-cell",
      "title_ger": ".episode-title-ger",
      "title_eng": ".episode-title-eng",
      "watched_class": "seen",
      "series_title": "h1.fw-bold",
      "description": ".series-description .description-text"
    },
    "subscription": {
      "action_button": ".js-action-btn",
      "active_class": "btn-glass-primary",
      "type_subscribed": "favorite",
      "type_watchlist": "watchlater"
    },
    "season_nav": {
      "pills": "#season-nav a[data-season-pill]",
      "pill_attribute": "data-season-pill"
    },
    "account_pages": {
      "subscribed": "/account/subscribed",
      "watchlist": "/account/watchlist"
    },
    "series_index": {
      "path": "/serien"
    }
  },
  "timing": {
    "initial_delay": 0.5,
    "element_timeout": 15,
    "season_nav_wait": 10.0,
    "element_find_timeout": 2,
    "page_ready_timeout": 10,
    "page_ready_body_timeout": 10,
    "login_response_timeout": 10,
    "process_lookup_timeout": 2,
    "addon_init_delay": 0.5,
    "worker_addon_init_delay": 0.3,
    "worker_service_init_delay": 0.1,
    "cookie_apply_page_ready_timeout": 5,
    "discovery_worker_stagger_delay": 1.0,
    "parallel_worker_stagger_delay": 2.0,
    "worker_auth_retry_delay": 1.0,
    "season_detection_browser_error_delay": 2.0,
    "season_detection_retry_delay": 1.0,
    "season_detection_retry_jitter": 0.5,
    "season_failure_backoff_step": 0.5,
    "season_failure_backoff_max": 2.0,
    "season_failure_backoff_jitter": 0.1,
    "missing_season_retry_delay": 0.2,
    "missing_season_retry_jitter": 0.1,
    "success_delay": 0.8,
    "error_backoff_base": 2.0,
    "error_backoff_max": 15.0,
    "error_backoff_502_base": 2.0,
    "error_backoff_502_max": 10.0,
    "min_request_interval": 0.25,
    "health_check_every": 15,
    "error_restart_threshold": 8,
    "max_retries_season": 3,
    "max_retries_retry": 5
  }
}
